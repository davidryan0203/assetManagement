# Copy this file to .env.local for local development
# On Vercel/Railway/Render, set these in the dashboard under Environment Variables

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/inventorySystem?retryWrites=true&w=majority

# JWT — use a long random string in production (e.g. openssl rand -base64 64)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# App name (exposed to browser)
NEXT_PUBLIC_APP_NAME=InventorySystem
